# Kopiraj u `.env` ili koristi vrednosti iz ~/sk/docker/docker-compose.yml za sk-mcp.

SK_API_URL=http://localhost:8082

# HMAC ka ridelogger-api (opciono; prazno = bez potpisa). Lokalni Docker default:
# API_CONSUMER_KEY_ID=docker-local
# API_CONSUMER_SECRET=sk-local-mcp-hmac-secret-not-for-prod
API_CONSUMER_CODE=mcp
API_CONSUMER_KEY_ID=
API_CONSUMER_SECRET=
